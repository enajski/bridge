{:enums
 {:system-categories ["distributed" "actor-message" "shared-memory" "lock-free" "async-runtime"
                      "api" "business-rule" "data-pipeline" "legacy" "other"]
  :concern-classes ["safety" "liveness" "performance" "code-level" "spec-fidelity"]
  :verification-methods ["model-checkable" "test-verifiable" "code-review-only" "out-of-scope"]
