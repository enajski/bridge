  :evidence-kinds ["unit" "property" "runtime" "differential" "trace-validation" "benchmark"
                   "proof" "model-check" "symbolic" "docs-or-nl-spec" "custom"]
  :requirement-levels ["required" "recommended" "optional" "forbidden"]
  :risk-classes ["low" "medium" "high"]
  :change-categories ["feature" "bugfix" "refactor" "spec-only" "code-only" "tests-only"
